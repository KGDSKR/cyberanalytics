# --- Ключи API (никогда не коммитить настоящий .env!) ---

# PandaScore — данные о матчах CS2 (https://app.pandascore.co → Dashboard → API Token)
PANDASCORE_TOKEN=

# Anthropic Claude — генерация ИИ-анализа (https://console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# Telegram-бот от @BotFather (нужен для проверки подписи initData)
TELEGRAM_BOT_TOKEN=
# true = пускать только запросы из Telegram; false = удобно для локальной разработки в браузере
REQUIRE_TG_AUTH=false

PORT=3000
