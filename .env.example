# --- Ключи API (никогда не коммитить настоящий .env!) ---

# PandaScore — данные о матчах CS2/Dota 2 (https://app.pandascore.co → Dashboard → API Token)
PANDASCORE_TOKEN=

# Провайдер ИИ: gemini | claude (auto = кто настроен)
AI_PROVIDER=gemini

# Google Gemini (https://aistudio.google.com → Get API key)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Anthropic Claude (https://console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# Steam Web API — live-драфты Dota 2, полное покрытие лиг (https://steamcommunity.com/dev/apikey)
# Без ключа работает запасной источник OpenDota (видит только топовые игры)
STEAM_API_KEY=

# GitHub — постоянное хранилище прогнозов для трекинга точности (ветка data)
GITHUB_TOKEN=
GITHUB_REPO=KGDSKR/cyberanalytics

# Telegram-бот от @BotFather (нужен для проверки подписи initData)
TELEGRAM_BOT_TOKEN=
# true = пускать только запросы из Telegram; false = удобно для локальной разработки в браузере
REQUIRE_TG_AUTH=false

PORT=3000
